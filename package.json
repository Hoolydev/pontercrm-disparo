{
  "name": "pointer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @pointer/db run generate",
    "db:migrate": "pnpm --filter @pointer/db run migrate",
    "db:studio": "pnpm --filter @pointer/db run studio",
    "db:seed": "pnpm --filter @pointer/db run seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2"
  }
}
