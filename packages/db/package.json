{
  "name": "@pointer/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "generate": "NODE_OPTIONS='--import tsx' drizzle-kit generate",
    "migrate": "tsx --env-file=../../.env src/migrate.ts",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: skip'",
    "test": "echo 'test: skip'"
  },
  "dependencies": {
    "@pointer/shared": "workspace:*",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
