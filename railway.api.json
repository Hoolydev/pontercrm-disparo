{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile --prod=false && pnpm --filter @pointer/api... build"
  },
  "deploy": {
    "preDeployCommand": ["pnpm --filter @pointer/db run migrate:prod"],
    "startCommand": "pnpm --filter @pointer/api start",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
